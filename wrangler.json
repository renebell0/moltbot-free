{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moltbot-free",
  "main": "src/index.ts",
  "compatibility_date": "2024-05-02",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "moltbot_db",
      "database_id": "7181b9c1-8088-4ec4-b2db-49a1c4ddc6b9"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "moltbot-files"
    }
  ],
  "vars": {
    "ALLOWED_USER_IDS": "",
    "TELEGRAM_BOT_TOKEN": "REPLACE_WITH_TOKEN",
    "GOOGLE_SEARCH_API_KEY": "REPLACE_WITH_KEY",
    "GOOGLE_SEARCH_CX": "REPLACE_WITH_CX"
  }
}
